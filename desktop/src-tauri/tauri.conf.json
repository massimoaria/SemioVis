{
  "productName": "SemioVis",
  "version": "1.0.0",
  "identifier": "com.semiovis.desktop",
  "build": {
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SemioVis — Visual Semiotic Analysis",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: http://localhost:* http://127.0.0.1:* https://*.googleapis.com https://*.openai.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../bin/**/*",
      "scripts/Install SemioVis.command"
    ]
  },
  "plugins": {}
}
